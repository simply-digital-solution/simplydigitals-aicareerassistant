# Copy this file to .env and fill in your values.

# App
APP_ENV=development
LOG_LEVEL=INFO

# Auth
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=sqlite+aiosqlite:////absolute/path/to/api/aicareercoach.db

# Ollama models (used when GEMINI_API_KEY is empty)
SPECIALIST_MODEL=deepseek-r1:7b
COORDINATOR_MODEL=deepseek-r1:7b

# Gemini — used for resume generation (quality-sensitive tasks)
# Get your key at https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Groq — used for bulk job scoring (14,400 RPD free tier vs Gemini's 1,500 RPD)
# Get your key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Google OAuth2 (Drive integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Job board credentials (never sent to the LLM)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
WORKDAY_EMAIL=
WORKDAY_PASSWORD=
GREENHOUSE_EMAIL=
GREENHOUSE_PASSWORD=
LEVER_EMAIL=
LEVER_PASSWORD=

# Optional integrations
NEWS_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
