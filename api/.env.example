# Copy this file to .env and fill in your values.
# Production: this file is written to the EC2 server by the CI deploy pipeline.
# Never commit a .env file with real values.

# App
APP_ENV=development        # set to "production" on EC2
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:5173                                      # prod: https://aicareerassistant.simplydigitals.com.sg
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000             # prod: https://aicareerassistant.simplydigitals.com.sg

# Scheduler — "false" in the api container (scheduler runs in its own container)
ENABLE_SCHEDULER=true

# Auth
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Database — PostgreSQL required for both dev and prod
# Local dev: docker run -d --name pg -e POSTGRES_PASSWORD=dev -e POSTGRES_DB=aicareer -p 5432:5432 postgres:15-alpine
DATABASE_URL=postgresql+asyncpg://postgres:dev@localhost:5432/aicareer

# Gemini — REQUIRED in production. Optional in dev (falls back to Ollama if empty).
# Get your key at https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite


# Google OAuth2 (Drive integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Job board credentials (never sent to the LLM)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
WORKDAY_EMAIL=
WORKDAY_PASSWORD=
GREENHOUSE_EMAIL=
GREENHOUSE_PASSWORD=
LEVER_EMAIL=
LEVER_PASSWORD=

# Optional integrations
NEWS_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
